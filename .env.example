SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Main site password (חמ״ל) — sent as x-hamal-key from the browser
HAMAL_SECRET=your_main_password

# Optional: per-station passwords (JSON object). Keys must match MSR_STATION_SLUG_BY_NAME in stations-config.js (e.g. lev, medical, registration).
# Example: {"lev":"secret-a","medical":"secret-b"}
HAMAL_STATION_KEYS=
